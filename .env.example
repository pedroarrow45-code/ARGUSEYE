DATABASE_URL=
BLOB_READ_WRITE_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BING_SEARCH_API_KEY=
SERP_API_KEY=
NEWS_API_KEY=
NEXT_PUBLIC_APP_URL=

# Self-hosted SearXNG instance used by the public OSINT investigation endpoint.
SEARXNG_BASE_URL=http://localhost:8080
DEMO_MODE=true
LIVE_MODE=false
BRASILAPI_ENABLED=true
MAX_RESULTS_PER_CASE=20
WIKIDATA_ENABLED=false
WIKIDATA_TIMEOUT_MS=3000
MAX_NAME_CANDIDATES_PER_CASE=5

# Google Custom Search JSON API has a limited free daily quota and can incur cost if billing is enabled. Keep disabled unless keys and quota policy are configured.
GOOGLE_SEARCH_ENABLED=false
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_SEARCH_TIMEOUT_MS=3000
MAX_GOOGLE_QUERIES_PER_CASE=2
MAX_WEB_RESULTS_PER_CASE=10
